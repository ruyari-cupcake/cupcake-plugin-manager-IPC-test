{
  "name": "cupcake-provider-v4",
  "version": "2.0.0-alpha.1",
  "type": "module",
  "description": "Cupcake Provider Manager v4 — IPC-based independent V3 plugins",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "verify": "node scripts/verify-build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run verify"
  },
  "devDependencies": {
    "rollup": "^4.34.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
