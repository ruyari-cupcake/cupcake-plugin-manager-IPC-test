{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "baseUrl": ".",
        "paths": {
            "./src/*": ["./src/*"]
        }
    },
    "include": ["src/shared/**/*.js", "src/shared/**/*.d.ts"],
    "exclude": ["node_modules", "dist", "tests"]
}
